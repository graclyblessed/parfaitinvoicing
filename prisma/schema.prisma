// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// NextAuth.js User model
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  settings      Settings?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// NextAuth.js Account model (for OAuth providers like Google)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth.js Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth.js Verification Token model (for email verification)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User settings for company info
model Settings {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String
  companyAddress  String
  companySIRET    String
  companySIREN    String
  companyTVA      String?
  presidentName   String?  // Nom du président de la SASU
  vatRegime       String   @default("franchise") // franchise, reel_simplifie, reel_normal
  fiscalYearStart Int      @default(1)  // Month (1 = January)
  fiscalYearEnd   Int      @default(12) // Month (12 = December)
  email           String
  googleCalendarId String?
  capital         Float    @default(0)    // BUG-009 FIX: Capital social for bilan
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Transaction categories for labeling
model Category {
  id          String   @id @default(cuid())
  name        String
  type        String   // income, expense
  color       String   @default("#3B82F6")
  icon        String?
  isDefault   Boolean  @default(false)
  taxDeductible  Boolean @default(true)
  defaultTvaRate Float   @default(0.20) // TVA rate for this category: 0, 0.055, 0.10, 0.20
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  transactions   Transaction[]
  expenses       Expense[]
  rules          CategoryRule[]
}

// Bank transactions from CSV
model Transaction {
  id              String   @id @default(cuid())
  date            DateTime
  amount          Float
  description     String
  reference       String?
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  type            String   @default("unknown") // income, expense, unknown
  labeled         Boolean  @default(false)
  bankAccount     String?
  rawCsvData      String?  // Original CSV row
  receiptUrl      String?  // Path to uploaded receipt
  receiptName     String?  // Original receipt filename
  notes           String?  // User notes
  taxPayments     TaxPayment[] // Tax payments linked to this transaction
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Devis (Quotes) created
model Devis {
  id              String   @id @default(cuid())
  devisNumber     String   @unique
  date            DateTime
  validUntil      DateTime // Date de validité du devis
  clientName      String
  clientAddress   String?
  clientSIRET     String?
  clientTVAIntra  String?  // Numéro TVA intracommunautaire du client
  clientEmail     String?  // For electronic sending
  items           String   // JSON array of line items
  subtotalHT      Float
  tvaRate         Float    @default(20.0)
  tvaAmount       Float
  totalTTC        Float
  status          String   @default("draft") // draft, sent, accepted, rejected, converted
  notes           String?
  sentAt          DateTime? // When devis was sent
  acceptedAt      DateTime? // When devis was accepted
  convertedToInvoiceId String? // Link to the created invoice
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Invoices created
model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  date            DateTime
  dueDate         DateTime
  clientName      String
  clientAddress   String?
  clientSIRET     String?
  clientTVAIntra  String?  // Numéro TVA intracommunautaire du client
  clientEmail     String?  // For electronic sending
  items           String   // JSON array of line items
  subtotalHT      Float
  tvaRate         Float    @default(20.0)
  tvaAmount       Float
  totalTTC        Float
  status          String   @default("draft") // draft, sent, paid, cancelled
  paidAt          DateTime?
  notes           String?
  devisId         String?  // Link to original devis if converted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Tax deadlines
model TaxDeadline {
  id              String   @id @default(cuid())
  name            String
  type            String   // IS, TVA, CFE, TVS, DAS2, LIASSE
  dueDate         DateTime
  periodStart     DateTime?
  periodEnd       DateTime?
  amount          Float?
  status          String   @default("pending") // pending, done, overdue
  notes           String?
  reminderSent    Boolean  @default(false)
  reminderSentAt  DateTime?
  calendarEventId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Expense entries (manual)
model Expense {
  id              String   @id @default(cuid())
  date            DateTime
  amount          Float
  description     String
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  receiptUrl      String?
  isPaid          Boolean  @default(true)
  paymentMethod   String?  // card, transfer, cash, check
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Cash flow projections
model CashFlowProjection {
  id              String   @id @default(cuid())
  month           Int
  year            Int
  projectedIncome Float    @default(0)
  projectedExpense Float   @default(0)
  taxPayment      Float    @default(0)
  actualIncome    Float    @default(0)
  actualExpense   Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([month, year])
}

// Liasse Fiscale (Tax Return) for SASU - Régime Simplifié
model LiasseFiscale {
  id              String   @id @default(cuid())
  year            Int
  status          String   @default("draft") // draft, complete, filed
  
  // Actif (Balance Sheet Assets) - Form 2033-A
  immoIncorporelles Float   @default(0)
  immoCorporelles  Float    @default(0)
  immoFinancieres  Float    @default(0)
  totalImmo        Float    @default(0)
  stocks           Float    @default(0)
  creancesClients  Float    @default(0)
  autresCreances   Float    @default(0)
  disponibilites   Float    @default(0)
  totalActifCirculant Float @default(0)
  totalActif       Float    @default(0)
  
  // Passif (Balance Sheet Liabilities)
  capital          Float    @default(0)
  reserves         Float    @default(0)
  reportANouveau   Float    @default(0)
  resultatExercice Float    @default(0)
  totalCapitauxPropres Float @default(0)
  emprunts         Float    @default(0)
  dettesFournisseurs Float @default(0)
  dettesFiscales   Float    @default(0)
  dettesSociales   Float    @default(0)
  autresDettes     Float    @default(0)
  totalDettes      Float    @default(0)
  totalPassif      Float    @default(0)
  
  // Compte de Résultat - Form 2033-D
  chiffreAffaires  Float    @default(0)
  productionStockee Float   @default(0)
  productionImmo   Float    @default(0)
  subventions      Float    @default(0)
  autresProduits   Float    @default(0)
  totalProduits    Float    @default(0)
  
  achats           Float    @default(0)
  variationStocks  Float    @default(0)
  servicesExterieurs Float @default(0)
  chargesPersonnel Float    @default(0)
  impotsTaxes      Float    @default(0)
  dotationsAmort   Float    @default(0)
  dotationsProvisions Float @default(0)
  chargesFinancieres Float @default(0)
  chargesExceptionnelles Float @default(0)
  totalCharges     Float    @default(0)
  
  resultatCourant  Float    @default(0)
  resultatExceptionnel Float @default(0)
  impotSurSocietes Float    @default(0)
  resultatNet      Float    @default(0)
  
  // Informations Complémentaires - Form 2033-G
  effectif         Int      @default(0)
  dureeExercice    Int      @default(12)
  loyers           Float    @default(0)
  chargesLocatives Float    @default(0)
  entretienReparation Float @default(0)
  primesAssurance  Float    @default(0)
  fraisDeplacement Float    @default(0)
  fraisPostaux     Float    @default(0)
  fraisTelecom     Float    @default(0)
  fraisBancaires   Float    @default(0)
  cadeaux          Float    @default(0)
  repasProfessionnels Float @default(0)
  formation        Float    @default(0)
  publiciteMarketing Float  @default(0)
  expertComptable  Float    @default(0)
  
  // Immobilisations details
  materielsOutils  Float    @default(0)
  materielsBureau  Float    @default(0)
  materielsInfo    Float    @default(0)
  vehicules        Float    @default(0)
  
  // TVA
  tvaCollectee     Float    @default(0)
  tvaDeductible    Float    @default(0)
  tvaDue           Float    @default(0)
  
  // Rémunérations
  remunerationGerant Float  @default(0)
  cotisationsSociales Float @default(0)
  
  // Déclaration Résultat - Form 2065
  resultatComptable Float   @default(0)
  retraitements    Float    @default(0)
  resultatFiscal   Float    @default(0)
  chargesDeductibles Float @default(0)
  deficitAnterieur Float    @default(0)
  deficitUtilise   Float    @default(0)
  baseImposableIS  Float    @default(0)
  isAPayer         Float    @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@unique([year])
}

// Category learning rules - auto-learned from user categorizations
model CategoryRule {
  id              String   @id @default(cuid())
  pattern         String   // Text pattern to match in description
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  transactionType String   // income or expense
  matchCount      Int      @default(1) // How many times this rule was applied
  lastUsed        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([pattern]) // One rule per pattern
}

// Formulaire 2572 - Relevé de solde IS (IS Balance Settlement)
model Formulaire2572 {
  id              String   @id @default(cuid())
  year            Int      // Fiscal year ending (e.g., 2025 for FY closing 30/11/2025)
  status          String   @default("draft") // draft, complete, filed

  // Section 1: Résultat de l'exercice
  resultatNetBenefice  Float  @default(0)   // Ligne I - Bénéfice net ou déficit
  resultatNetDeficit   Float  @default(0)   // Ligne I (if negative)
  
  // Section 2: IS dû au taux normal (25%)
  baseTauxNormal       Float  @default(0)   // Ligne II - Base imposable au taux normal
  isTauxNormal         Float  @default(0)   // Ligne II - IS au taux normal (25%)
  
  // Section 3: IS au taux réduit (15%)
  baseTauxReduit       Float  @default(0)   // Ligne III - Base imposable au taux réduit
  isTauxReduit         Float  @default(0)   // Ligne III - IS au taux réduit (15%)
  
  // Section 4: Crédits d'impôt imputables
  creditImpotRecherche       Float @default(0)  // CIR
  creditImpotInnovation      Float @default(0)  // CII
  creditImpotCooperation     Float @default(0)  // CCor
  creditImpotApprentissage   Float @default(0)  // Crédit d'apprentissage
  creditImpotFamille         Float @default(0)  // CAF
  creditImpotMEC             Float @default(0)  // Mécénat
  creditImpotCompetitivite   Float @default(0)  // CICE (ancien)
  creditImpotAgri            Float @default(0)  // Crédit agricole
  creditImpotAutres          Float @default(0)  // Autres crédits
  totalCreditsImpot          Float @default(0)  // Total crédits d'impôt
  
  // Section 5: IS net et acomptes
  totalISBrut           Float  @default(0)   // IS brut (taux normal + réduit)
  totalISNet            Float  @default(0)   // IS après imputation crédits
  
  // Acomptes versés
  acompte1              Float  @default(0)   // 1er acompte (15 mars)
  acompte2              Float  @default(0)   // 2e acompte (15 juin)
  acompte3              Float  @default(0)   // 3e acompte (15 sept.)
  acompte4              Float  @default(0)   // 4e acompte (15 déc.)
  totalAcomptes         Float  @default(0)   // Total acomptes versés
  
  // Section 6: Solde / Excédent
  soldeAPayer           Float  @default(0)   // Solde à payer (if IS net > acomptes)
  excedent             Float  @default(0)   // Excédent à rembourser (if acomptes > IS net)
  
  // Contributions additionnelles
  cfb                   Float  @default(0)   // Contribution sur les bénéfices
  contributionSociale   Float  @default(0)   // Contribution sociale
  
  // Impôts étrangers (crédits d'impôt)
  impotsEtrangersCr     Float  @default(0)   // Ligne 7 - Impôts payés à l'étranger
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@unique([year])
}

// Formulaire 2065 - Déclaration des bénéfices (IS Declaration)
model Formulaire2065 {
  id              String   @id @default(cuid())
  year            Int      // Fiscal year ending
  status          String   @default("draft") // draft, complete, filed

  // Identification
  regimeBenefice  String   @default("RS") // RS (Réel Simplifié), RN (Réel Normal)
  dureeExercice   Int      @default(12)  // Duration in months
  dateCloture     String   @default("")  // Closing date string (30/11/YYYY)

  // Section 1: Résultat comptable et fiscal
  resultatComptable     Float  @default(0)  // Ligne 1 - Résultat comptable
  reintegrationNeutralite Float @default(0)  // Réintégrations neutralisées (art. 223 octies)
  deductionsNeutralite  Float @default(0)   // Déductions neutralisées
  resultatFiscal        Float  @default(0)  // Ligne 3 - Résultat fiscal net
  
  // Section 2: Déficits reportables
  deficitAnterieurN1    Float  @default(0)  // Ligne 4 - Déficit N-1
  deficitAnterieurN2    Float  @default(0)  // Ligne 5 - Déficit N-2
  deficitAnterieurN3    Float  @default(0)  // Ligne 6 - Déficits antérieurs
  totalDeficits         Float  @default(0)  // Total déficits imputables
  deficitUtilise        Float  @default(0)  // Déficits effectivement utilisés
  
  // Section 3: Base imposable
  baseImposableAvant    Float  @default(0)  // Base avant déduction déficits
  baseImposable         Float  @default(0)  // Ligne 7 - Base imposable nette
  
  // Section 4: Calcul de l'IS
  baseTauxReduit        Float  @default(0)  // Part de la base au taux réduit 15%
  baseTauxNormal        Float  @default(0)  // Part de la base au taux normal 25%
  isTauxReduit          Float  @default(0)  // IS au taux réduit (15%)
  isTauxNormal          Float  @default(0)  // IS au taux normal (25%)
  isTotal               Float  @default(0)  // IS total brut
  
  // Section 5: Crédits d'impôt
  creditImpotRecherche       Float @default(0)
  creditImpotInnovation      Float @default(0)
  creditImpotCooperation     Float @default(0)
  creditImpotApprentissage   Float @default(0)
  creditImpotFamille         Float @default(0)
  creditImpotMEC             Float @default(0)
  creditImpotAutres          Float @default(0)
  totalCreditsImpot          Float @default(0)
  
  // Section 6: IS net et contributions
  isNet                 Float  @default(0)  // IS net à payer
  contributionSociale   Float  @default(0)  // Contribution sociale (3.3%)
  cfb                   Float  @default(0)  // CFB
  
  // Section 7: Répartition géographique des bénéfices
  beneficeFrance        Float  @default(0)  // Bénéfices imposables en France
  beneficeEtranger      Float  @default(0)  // Bénéfices imposables à l'étranger
  totalBenefice         Float  @default(0)  // Total bénéfices
  
  // Section 8: Informations spécifiques
  revenusBrevets        Float  @default(0)  // Revenus de brevets (taux 10%)
  revenusPatrimoineMobilier Float @default(0) // Revenus de patrimoine mobilier
  
  // Section 9: Précompte et acomptes
  precompteIS           Float  @default(0)  // Précompte déduit
  acomptesVerses        Float  @default(0)  // Acomptes versés au titre de l'exercice
  
  // Section 10: Références aux annexes
  annexesFournies       String  @default("")  // JSON list of annexes (2065-BIS, 2033-A, etc.)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@unique([year])
}

// Formulaire 3517-S - Déclaration annuelle de TVA (CA12) - Régime Simplifié
model Formulaire3517S {
  id              String   @id @default(cuid())
  year            Int      // Fiscal year ending (e.g., 2025 for FY closing 30/11/2025)
  status          String   @default("draft") // draft, complete, filed

  // Section 1: TVA collectée (VAT collected on sales)
  // Ligne 5A - Taux normal 20%
  baseHT20        Float    @default(0)   // Base HT (sales at 20%)
  tvaCollectee20  Float    @default(0)   // TVA collected at 20%
  
  // Ligne 5B - Taux intermédiaire 10%
  baseHT10        Float    @default(0)   // Base HT (sales at 10%)
  tvaCollectee10  Float    @default(0)   // TVA collected at 10%
  
  // Ligne 5C - Taux réduit 5.5%
  baseHT55        Float    @default(0)   // Base HT (sales at 5.5%)
  tvaCollectee55  Float    @default(0)   // TVA collected at 5.5%
  
  // Ligne 5D - Taux particulier 2.1%
  baseHT21        Float    @default(0)   // Base HT (sales at 2.1%)
  tvaCollectee21  Float    @default(0)   // TVA collected at 2.1%

  // Ligne 16 - Total TVA brute due
  totalTVABrute   Float    @default(0)   // Sum of all collected TVA
  
  // Ligne 18 - Total base HT
  totalBaseHT     Float    @default(0)   // Sum of all base HT

  // Section 2: TVA déductible (VAT deductible on purchases)
  // Ligne 20 - TVA on goods and services (current expenses)
  tvaDeductibleBiensServices  Float  @default(0)
  
  // Ligne 21 - TVA on immobilizations (equipment, etc.)
  tvaDeductibleImmobilisations Float @default(0)
  
  // Ligne 22 - Total TVA déductible
  totalTVADeductible  Float  @default(0)
  
  // Ligne 26 - Total deductions
  totalDeductions     Float  @default(0)

  // Section 3: TVA nette
  // Ligne 28 - TVA due (or credit)
  tvaNette        Float    @default(0)   // totalTVABrute - totalTVADeductible
  
  // Ligne 33 - Crédit de TVA à reporter (if negative)
  creditTVA       Float    @default(0)   // max(0, -tvaNette)
  
  // Ligne 54 - TVA nette due
  tvaNetteDue     Float    @default(0)   // max(0, tvaNette)
  
  // Ligne 56 - Total à payer
  totalAPayer     Float    @default(0)   // = tvaNetteDue

  // Metadata
  periodeStart    String   @default("")   // e.g. "01/12/2024"
  periodeEnd      String   @default("")   // e.g. "30/11/2025"
  
  // Source data counts
  nombreVentes    Int      @default(0)   // Number of invoices/transactions used
  nombreAchats    Int      @default(0)   // Number of purchase transactions used

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@unique([year])
}

// Tax declarations (IS, TVA)
model Declaration {
  id              String   @id @default(cuid())
  type            String   // IS, TVA
  year            Int
  period          String   // FY2025, Q1-2025, CA12-2025
  amount          Float    @default(0)
  status          String   @default("pending") // pending, filed, paid
  dueDate         DateTime
  filedAt         DateTime?
  documentUrl     String?  // Path to uploaded document
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Tax payments linked to this declaration
  taxPayments     TaxPayment[]

  @@unique([type, year, period])
}

// Tax Payment - records actual payments made to tax authorities (impots.gouv.fr)
model TaxPayment {
  id              String   @id @default(cuid())
  
  // What tax was paid
  taxType         String   // IS, TVA, CFE, TVS, CVA, DAS2, CIR, CII, OTHER
  declarationId   String?  // Link to Declaration if created from a declaration
  declaration     Declaration? @relation(fields: [declarationId], references: [id], onDelete: SetNull)
  
  // Fiscal year and period
  year            Int      // Fiscal year the payment relates to
  period          String   // e.g., "IS-Q1-2025", "CA12-2025", "CFE-2025", "TVA-Accompte-Juillet-2025"
  label           String   // Free text label e.g. "Acompte IS Q1 2025", "TVA CA12 2024", "CFE 2025"
  
  // Payment details
  amount          Float    // Amount actually paid
  paymentDate     DateTime // Date payment was made
  dueDate         DateTime? // Original due date (for late payment tracking)
  paymentMethod   String?  // "telepaiement", "virement", "prelevement", "cheque", "autre"
  reference       String?  // impots.gouv.fr reference / télé-règlement number
  status          String   @default("completed") // "completed", "pending", "cancelled", "adjusted"
  
  // Bank reconciliation
  transactionId   String?  // Link to matching bank Transaction
  transaction     Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  
  // Proof & notes
  receiptUrl      String?  // Uploaded receipt/screenshot from impots.gouv.fr
  notes           String?
  
  // Metadata
  isHistorical    Boolean  @default(false) // true if entered after the fact (prior period)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([taxType, year])
  @@index([paymentDate])
  @@index([declarationId])
}

// Formulaire 1329-DEF — Déclaration de liquidation et de régularisation de la CVAE
// Version applicable au 01/01/2025 (loi de finances 2025 - loi n° 2025-127 du 14/02/2025).
// Solde annuel : compare CVAE due (N) aux acomptes versés → solde à payer ou excédent.
// Échéance : 5 mai N+1. CVAE non supprimée (reportée à 2030).
// Contribution complémentaire 47,4 % : 2025 uniquement. Franchise : 63 €.
model Formulaire1329DEF {
  id              String   @id @default(cuid())
  year            Int      // Année d'imposition (ex: 2025 pour CVAE 2025, déposée en 2026)
  status          String   @default("draft") // draft, complete, filed

  // Section I : Chiffre d'affaires
  ligne01_CA_periode_reference   Float  @default(0)
  ligne02_CA_reel                Float  @default(0)
  ligne03_CA_groupe              Float  @default(0)
  ligne04_pourcentage_VA         Float  @default(0)

  // Section II : Valeur ajoutée
  ligne05_VA_produite            Float  @default(0)
  ligne06_limitation_VA          Boolean @default(false)
  ligne07_CVAE_brute             Float  @default(0)

  // Section III : Cotisation
  ligne08_cotisation_avant_reduction  Float  @default(0)
  ligne09_exonerations               Float  @default(0)
  ligne10_reduction_supplementaire   Float  @default(0)
  ligne11_CVAE_due                   Float  @default(0) // 0 si ≤ 63 € (franchise)

  ligne12_acomptes_CVAE         Float  @default(0)
  ligne13_solde_CVAE_payer      Float  @default(0)
  ligne14_excedent_CVAE         Float  @default(0)

  ligne15_taxe_add_due          Float  @default(0) // 13,84 % de L11 (9,23 % si cessation)
  ligne16_acomptes_taxe_add     Float  @default(0)
  ligne17_solde_taxe_add_payer  Float  @default(0)
  ligne18_excedent_taxe_add     Float  @default(0)

  ligne20_contrib_compl_due      Float  @default(0) // L11 × 47,4 % (2025 uniquement)
  ligne21_acompte_contrib_compl  Float  @default(0)
  ligne22_solde_contrib_payer    Float  @default(0)
  ligne23_excedent_contrib       Float  @default(0)

  // Section IV : Paiement ou excédent
  ligne24_total_acomptes        Float  @default(0) // L12 + L16 + L21
  ligne25_total_payer           Float  @default(0) // L13 + L17 + L22
  ligne26_total_excedents       Float  @default(0) // L14 + L18 + L23
  ligne27_CVAE_DUE_paiement     Float  @default(0) // L25 - L26 si > 0
  ligne28_excedent_versement     Float  @default(0) // L26 - L25 si > 0 → joindre RIB

  // Métadonnées
  cessation_2026                Boolean @default(false)
  exonere_taxe_additionnelle    Boolean @default(false) // Case: exonéré taxe additionnelle (artisans, coopératives, etc.)
  effectifsSalaries             Int     @default(0)
  periodeLabel                  String  @default("")
  reference_teletransmission    String?
  filedAt                       DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([year])
}
